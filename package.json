{
  "name": "uniqtab",
  "version": "1.2.4",
  "main": "index.js",
  "repository": "https://github.com/mkusaka/uniqtab.git",
  "author": "mkusaka <hinoshita1992@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@11.15.1",
  "devDependencies": {
    "@crxjs/vite-plugin": "2.7.1",
    "@types/chrome": "0.2.2",
    "lefthook": "2.1.10",
    "prettier": "3.9.5",
    "typescript": "7.0.2",
    "vite": "8.1.5"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "package": "rm -f package.zip && pnpm build && cd dist && zip -r ../package.zip .",
    "prepare": "lefthook install"
  }
}
